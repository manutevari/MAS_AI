LLM_PROVIDER=local

OPENAI_API_KEY=
GROK_API_KEY=
GROK_BASE_URL=https://api.x.ai/v1
GROK_MODEL=grok-2-latest

GOOGLE_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

HF_TOKEN=
HF_BASE_URL=https://router.huggingface.co/v1
HF_MODEL=meta-llama/Llama-3.1-8B-Instruct

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct
TAVILY_API_KEY=

OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.1

CUSTOM_LLM_API_KEY=
CUSTOM_LLM_API_KEY_ENV=CUSTOM_LLM_API_KEY
CUSTOM_LLM_BASE_URL=https://example.com/v1
CUSTOM_LLM_MODEL=provider/model-name

OCR_LANG=eng
OCR_ENGINE=tesseract
TRANSLITERATION_ENGINE=none
STT_ENGINE=manual
OPENAI_STT_MODEL=whisper-1
TTS_ENGINE=manual_external
DPDP_LAWFUL_BASIS=false
DPDP_CLOUD_CONSENT=false
DPDP_REDACT=true
COMPLIANCE_JURISDICTION=Global/Unknown
HUMAN_REVIEW_CONFIRMED=false
REQUIRE_HUMAN_EXPORT_APPROVAL=true
DATABASE_URL=postgresql://user:password@host:5432/database
